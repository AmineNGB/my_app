<div class="container mt-5">

  <!-- Header -->
  <header class="hero-section text-center mb-5">
    <h1 class="display-4">Bienvenue sur Secret Aïd <%= Date.current.year %> 🌙</h1>
    <p class="lead">Organisez facilement un tirage au sort pour votre échange de cadeaux !</p>
  </header>

  <!-- Exclusions -->
  <div class="row justify-content-center mb-5">
    <div class="col-12 col-md-10 col-lg-8">
      <div class="card shadow-sm border-0 rounded-4 p-4">
        <h4 class="fw-bold mb-2">🚫 Gérer mes exclusions</h4>
        <p class="text-muted mb-3">
          Indiquez les personnes à qui vous ne souhaitez 
          <strong>ni offrir</strong> ni <strong>recevoir</strong> de cadeau.
        </p>
        <ul class="list-unstyled mb-4 small text-muted">
          <li>• Le nombre d'exclusions est limité au nombre de participants du <strong>genre opposé</strong>.</li>
          <li>• Vous pouvez modifier vos exclusions à tout moment avant le tirage.</li>
        </ul>
        <div class="text-center">
          <%= link_to edit_exclusions_path, class: "btn btn-primary btn-lg rounded-3 px-4" do %>
            ✏️ Modifier mes exclusions
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Groupes -->
  <div class="row g-4">
    <% @groups.each do |group| %>
      <% user_draw = @draws.find { |d| d.group_id == group.id && d.user_id == current_user.id } %>
      <% draw_done = group.draws.exists? %>

      <% next if draw_done && !group.users.include?(current_user) %>

      <div class="col-12 col-md-6 col-lg-4">
        <div class="card shadow-sm h-100 rounded-4 p-3 d-flex flex-column justify-content-between">

          <!-- Titre et état du tirage -->
          <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h5 class="fw-bold mb-0"><%= group.name %></h5>
              <% if draw_done %>
                <span class="text-success" title="Tirage effectué">✅</span>
              <% else %>
                <span class="text-warning" title="Tirage pas encore fait">⏳</span>
              <% end %>
            </div>

            <!-- Tirage déjà effectué -->
            <% if user_draw %>
              <div class="text-center mb-3">
                <% if user_draw.recipient.avatar.attached? %>
                  <%= cl_image_tag(user_draw.recipient.avatar.key, transformation: [
                        {gravity: "face", height: 150, width: 150, crop: "thumb"},
                        {radius: "max"},
                        {fetch_format: "auto"}
                      ], class: "img-fluid rounded-circle mx-auto d-block mb-2") %>
                <% else %>
                  <%= image_tag "https://images.unsplash.com/photo-1601027847350-0285867c31f7?q=80&w=1974&auto=format&fit=crop&ixlib=rb-4.0.3",
                        class: "img-fluid rounded-circle mx-auto d-block mb-2", width: 150, height: 150 %>
                <% end %>
                <p class="fw-bold mb-1">Tu offres un cadeau à :</p>
                <h6 class="text-success mb-2"><%= user_draw.recipient.username %></h6>
                <small class="text-muted">Tirage effectué ✅</small>
              </div>
            <% else %>
              <div class="text-center mb-3">
                <p class="text-muted">Le tirage n'a pas encore eu lieu pour ce groupe</p>
              </div>
            <% end %>

            <!-- Participants en ligne -->
            <% if group.users.include?(current_user) %>
              <div class="mt-3">
                <h6 class="fw-semibold mb-2 text-center">Participants</h6>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                  <% group.users.each do |user| %>
                    <div class="text-center" style="width: 50px;">
                      <% if user.avatar.attached? %>
                        <%= cl_image_tag(user.avatar.key, transformation: [
                              {gravity: "face", height: 50, width: 50, crop: "thumb"},
                              {radius: "max"},
                              {fetch_format: "auto"}
                            ], class: "rounded-circle") %>
                      <% else %>
                        <div class="rounded-circle bg-secondary" style="width:50px; height:50px;"></div>
                      <% end %>
                      <small class="d-block text-truncate"><%= user.username %></small>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Boutons tout en bas -->
          <div class="text-center mt-3">
            <% if !group.users.include?(current_user) %>
              <%= button_to "Rejoindre le groupe", join_group_path(group), method: :post, class: "btn btn-primary w-75 mb-2" %>
            <% elsif !draw_done %>
              <%= button_to "Quitter le groupe", leave_group_path(group), method: :post, class: "btn btn-outline-danger w-75 mb-2", data: { confirm: "Es-tu sûr de vouloir quitter ce groupe ?" } %>
            <% end %>
          </div>

        </div>
      </div>
    <% end %>
  </div>
</div>