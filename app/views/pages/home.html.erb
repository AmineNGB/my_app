<div class="container mt-5">

  <header class="hero-section text-center mb-5">
    <h1 class="display-4">Bienvenue sur Secret Aïd <%= Date.current.year %> 🌙</h1>
    <p class="lead">Organisez facilement un tirage au sort pour votre échange de cadeaux !</p>
  </header>

  <div class="row g-4">
    <% @groups.each do |group| %>
      <% user_draw = @draws.find { |d| d.group_id == group.id && d.user_id == current_user.id } %>
      <% draw_done = group.draws.exists? %>

      <% # Ne pas afficher si tirage fait et je ne suis pas membre %>
      <% next if draw_done && !group.users.include?(current_user) %>

      <div class="col-12 col-md-6 col-lg-4">
        <div class="card shadow-sm h-100 rounded-4 p-3">

          <!-- Titre du groupe + état tirage -->
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0"><%= group.name %></h5>
            <% if draw_done %>
              <span class="text-success" title="Tirage effectué">✅</span>
            <% else %>
              <span class="text-warning" title="Tirage pas encore fait">⏳</span>
            <% end %>
          </div>

          <% if user_draw %>
            <!-- Cas : Tirage effectué et je suis dedans -->
            <div class="text-center mb-3">
              <% if user_draw.recipient.avatar.attached? %>
                <%= cl_image_tag(user_draw.recipient.avatar.key, transformation: [
                      {gravity: "face", height: 150, width: 150, crop: "thumb"},
                      {radius: "max"},
                      {fetch_format: "auto"}
                    ], class: "img-fluid rounded-circle mx-auto d-block mb-2") %>
              <% else %>
                <%= image_tag "https://images.unsplash.com/photo-1601027847350-0285867c31f7?q=80&w=1974&auto=format&fit=crop&ixlib=rb-4.0.3", 
                      class: "img-fluid rounded-circle mx-auto d-block mb-2", width: 150, height: 150 %>
              <% end %>
              <p class="fw-bold mb-1">Tu offres un cadeau à :</p>
              <h6 class="text-success mb-2"><%= user_draw.recipient.username %></h6>
              <small class="text-muted">Tirage effectué ✅</small>
            </div>
          <% else %>
            <!-- Tirage pas encore fait, possibilité de rejoindre -->
            <div class="text-center mb-3">
              <p class="text-muted">Le tirage n'a pas encore eu lieu pour ce groupe</p>
              <% unless group.users.include?(current_user) %>
                <%= button_to "Rejoindre le groupe", join_group_path(group), method: :post, class: "btn btn-primary" %>
              <% else %>
                <span class="badge bg-warning text-dark">En attente du tirage...</span>
              <% end %>
            </div>
          <% end %>

          <!-- Participants visibles seulement si je fais partie du groupe -->
          <% if group.users.include?(current_user) %>
            <div class="mt-3">
              <h6 class="fw-semibold">Participants</h6>
              <div class="d-flex flex-wrap gap-2">
                <% group.users.each do |user| %>
                  <div class="text-center" style="width: 50px;">
                    <% if user.avatar.attached? %>
                      <%= cl_image_tag(user.avatar.key, transformation: [
                            {gravity: "face", height: 50, width: 50, crop: "thumb"},
                            {radius: "max"},
                            {fetch_format: "auto"}
                          ], class: "rounded-circle") %>
                    <% else %>
                      <div class="rounded-circle bg-secondary" style="width:50px; height:50px;"></div>
                    <% end %>
                    <small class="d-block text-truncate"><%= user.username %></small>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    <% end %>
  </div>
</div>