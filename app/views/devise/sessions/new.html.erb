<div class="container d-flex align-items-center justify-content-center vh-100">
  <div class="card shadow-lg p-4 rounded-4" style="width: 100%; max-width: 420px;">
    
    <div class="text-center mb-4">
      <h2 class="fw-bold">Connexion</h2>
      <p class="text-muted small mb-0">Accède à ton espace</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="mb-3">
        <%= f.label :username, "Nom d'utilisateur", class: "form-label fw-semibold" %>
        <%= f.text_field :username,
              autofocus: true,
              class: "form-control form-control-lg rounded-3",
              placeholder: "Entre ton username" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "Mot de passe", class: "form-label fw-semibold" %>
        <%= f.password_field :password,
              class: "form-control form-control-lg rounded-3",
              placeholder: "••••••••",
              autocomplete: "current-password" %>
      </div>

      <div class="d-grid">
        <%= f.button :submit,
              "Je me connecte",
              class: "btn btn-primary btn-lg rounded-3" %>
      </div>

      <div class="text-center mt-3">
        <small class="text-muted">
          Nouveau compte ?
          <%= link_to "Créer un compte", new_user_registration_path, class: "fw-semibold text-decoration-none" %>
        </small>
      </div>

    <% end %>

  </div>
</div>