<div class="container d-flex align-items-center justify-content-center vh-100">
  <div class="card shadow-lg p-4 rounded-4" style="width: 100%; max-width: 480px;">

    <div class="text-center mb-4">
      <h2 class="fw-bold">Créer un compte</h2>
      <p class="text-muted small mb-0">Rejoins l'aventure 🎁</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { multipart: true }) do |f| %>

      <%= f.error_notification %>

      <div class="mb-3">
        <%= f.label :username, "Nom d'utilisateur", class: "form-label fw-semibold" %>
        <%= f.text_field :username,
              autofocus: true,
              class: "form-control form-control-lg rounded-3",
              placeholder: "Choisis un username" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Mot de passe", class: "form-label fw-semibold" %>
        <%= f.password_field :password,
              class: "form-control form-control-lg rounded-3",
              placeholder: "••••••••",
              autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <div class="form-text">
            <%= @minimum_password_length %> caractères minimum
          </div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "form-label fw-semibold" %>
        <%= f.password_field :password_confirmation,
              class: "form-control form-control-lg rounded-3",
              placeholder: "••••••••",
              autocomplete: "new-password" %>
      </div>

      <div class="mb-3">
        <%= f.label :avatar, "Photo de profil", class: "form-label fw-semibold" %>
        <%= f.file_field :avatar,
              class: "form-control rounded-3" %>
      </div>

      <div class="mb-4">
        <%= f.label :gender, "Genre", class: "form-label fw-semibold" %>
        <%= f.select :gender,
              [["Homme", "H"], ["Femme", "F"]],
              {},
              class: "form-select form-select-lg rounded-3" %>
      </div>

      <div class="d-grid">
        <%= f.button :submit,
              "Créer mon compte",
              class: "btn btn-primary btn-lg rounded-3" %>
      </div>

      <div class="text-center mt-3">
        <small class="text-muted">
          Déjà un compte ?
          <%= link_to "Se connecter", new_user_session_path, class: "fw-semibold text-decoration-none" %>
        </small>
      </div>

    <% end %>

  </div>
</div>