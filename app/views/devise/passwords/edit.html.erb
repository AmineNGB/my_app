<div class="container d-flex align-items-center justify-content-center vh-100">
  <div class="card shadow-lg p-4 rounded-4" style="width: 100%; max-width: 420px;">
    
    <div class="text-center mb-4">
      <h2 class="fw-bold">Réinitialiser le mot de passe</h2>
      <p class="text-muted small mb-0">
        Entre ton nouveau mot de passe pour ton compte.

      </p>
      <p class="text-muted small mb-0">
        Oublie le pas cette fois ci !        
      </p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <%= f.input :reset_password_token, as: :hidden %>
      
      <div class="mb-4">
        <%= f.label :password, "Nouveau mot de passe", class: "form-label fw-semibold" %>
        <%= f.password_field :password,
              required: true,
              autofocus: true,
              class: "form-control form-control-lg rounded-3",
              placeholder: "••••••••",
              autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <small class="text-muted">Minimum <%= @minimum_password_length %> caractères</small>
        <% end %>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "form-label fw-semibold" %>
        <%= f.password_field :password_confirmation,
              required: true,
              class: "form-control form-control-lg rounded-3",
              placeholder: "••••••••",
              autocomplete: "new-password" %>
      </div>

      <div class="d-grid mb-3">
        <%= f.button :submit, "Changer mon mot de passe", class: "btn btn-primary btn-lg rounded-3" %>
      </div>

      <div class="text-center">
        <small class="text-muted">
          Tu te souviens de ton mot de passe ?
          <%= link_to "Retour à la connexion",
                new_user_session_path,
                class: "fw-semibold text-decoration-none" %>
        </small>
      </div>
    <% end %>

  </div>
</div>